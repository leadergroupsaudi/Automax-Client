# VITE_API_URL=http://localhost:8080/api/v1
VITE_API_URL=https://vd2.automaxsw.com/ax3/api/v1

# WebSocket URL for real-time updates
# For local development
# VITE_WS_URL=ws://localhost:8080
# For production (uncomment the line below)
VITE_WS_URL=wss://vd2.automaxsw.com/ax3

# Base path for deployment (e.g. /ax3/ for subpath deployment)
VITE_BASE_PATH=/

# Login methods visibility (set to "false" to hide)
VITE_LOGIN_REGULAR=true
VITE_LOGIN_LDAP=false
VITE_LOGIN_SSO=false

# Only for vd2 client, set to "VD2" to enable vd2 specific features
VITE_CLIENT="VD2"